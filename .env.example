## Render env vars for DesignerWeb contact form
#
# SMTP settings (use your mail provider / transactional email)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
#
# Where to receive leads
TO_EMAIL=hello@designerweb.cz
#
# Must be a real sender address allowed by your SMTP provider
FROM_EMAIL=no-reply@designerweb.cz

